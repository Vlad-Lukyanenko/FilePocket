@page "/pockets/{PocketIdParam}/files/{FileIdParam}"

<div class="container">
    <div class="container w-75 pt-3 pb-3">
        @if (_file is not null)
        {
            <div class="row d-flex justify-content-end">
                <a href="/pockets/{@_pocketId}/files" class="btn btn-outline-secondary" style="width:6em; margin-right:0.8em;">Go back</a>
            </div>

            <br />

            <div class="w-100 text-center">
                <table class="table table-light  mx-auto">
                    <thead>
                        <tr>
                            <th scope="col" class="col">Name</th>
                            <th scope="col" class="col">Size</th>
                            <th scope="col" class="col">Type</th>
                            <th scope="col" class="col">Created at</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                @_file.OriginalName
                            </td>
                            <td>
                                @_file.FileSize
                            </td>
                            <td>
                                @_file.FileType
                            </td>
                            <td>
                                @_file.DateCreated
                            </td>
                        </tr>
                    </tbody>
                </table>
                
                <br />

                <img class="mw-100" src="@_imageContent" />
                
            </div>
        }
    </div>
</div>

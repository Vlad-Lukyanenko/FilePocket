@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase

<RadzenComponents />
<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Class="rz-pr-3" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0">
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />
            <RadzenLabel Text="File storage" />    
            <AuthorizeView>
                <Authorized>
                    <RadzenButton Class="rz-ml-auto" Click="Logout" Variant="Variant.Text" Text="Logout" Icon="logout" ButtonStyle="ButtonStyle.Light" />
                </Authorized>
            </AuthorizeView>                                                     
        </RadzenStack>        
    </RadzenHeader>
    <AuthorizeView>
        <Authorized>
            <RadzenSidebar @bind-Expanded="@sidebarExpanded">
                <NavMenu />
            </RadzenSidebar>
        </Authorized>
    </AuthorizeView>    
    <RadzenBody>
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>
